{
  // -------------------------------------------------------------------------
  // Global configuration
  // -------------------------------------------------------------------------

  "layer": "top",
  "position": "top",
  // "height": 20,

  "margin-left": 0,
  "margin-top": 0,
  "margin-bottom": 0,
  "margin-right": 0,

  "spacing": 0,
  "reload_style_on_change": true,

  // -------------------------------------------------------------------------
  // Layout
  // -------------------------------------------------------------------------

  "modules-left": [
    // "custom/rofi",
    "group/workspaces-left",
    "hyprland/workspaces",
    "group/workspaces-right",
    // "hyprland/submap",
    // "temperature",
    "hyprland/window",
    "group/window-right"
    // "idle_inhibitor"
    // "mpd"
    // "custom/spotify"
  ],
  "modules-center": [
    
    "custom/task"
  ],
  "modules-right": [
    // "backlight",
    "group/stats-left",
    "group/stats",
    "group/stats-right",
    "group/services-left",
    "group/services",
    "group/services-right",
    "custom/power"
  ],

  // -------------------------------------------------------------------------
  // Groups
  // -------------------------------------------------------------------------

  "group/stats": {
    "orientation": "horizontal",
    "modules": [
      "custom/vpn",
      // "network",
      "memory",
      // "cpu",
      // "battery",
      "wireplumber",
      "hyprland/language"
    ]
  },

  "group/services": {
    "orientation": "horizontal",
    "modules": [
      "custom/camera",
      "bluetooth",
      "group/tray-group",
      "custom/theme",
      "clock"
    ]
  },
  
  "group/tray-group": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 300,
      "transition-left-to-right": false
    },
    "modules": [
      "custom/tray-button",
      "tray"
    ]
  },

  "custom/tray-button": {
    "format": "’ÉÄ",
    "tooltip": false
  },

  // -------------------------------------------------------------------------
  // Modules
  // -------------------------------------------------------------------------

  "custom/screenshot_t": {
    "format": "’Ć░ ",
    "on-click": "~/.config/hypr/scripts/screenshot_full",
    "on-click-right": "~/.config/hypr/scripts/screenshot_area"
  },

  "temperature": {
    // "thermal-zone": 1,
    "interval": 4,
    //"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon9/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "’ŗē {temperatureC}┬░C",
    "format-critical": "’ü▒  {temperatureC}┬░C",
    "format": "{icon}  {temperatureC}┬░C",
    "format-icons": ["’Ø½", "’ŗē", "’Ø®"],
    "max-length": 7,
    "min-length": 7,
    "on-click": "xsensors"
  },

  "memory": {
    "interval": 30,
    "format": "\uefc5 {used:0.2f} / {total:0.0f} GB",
    "on-click": "alacritty -e btop"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü«",
      "deactivated": "’ü░"
    },
    "tooltip": "true"
  },

  "custom/pacman": {
    "format": "<big>¶Åå▓</big>  {}",
    "interval": 3600, // every hour
    "exec": "checkupdates | wc -l", // # of updates
    "exec-if": "exit 0", // always run; consider advanced run conditions
    "on-click": "alacritty -e 'paru'; pkill -SIGRTMIN+8 waybar", // update system
    "signal": 8,
    "max-length": 5,
    "min-length": 3
  },

  "custom/power": {
    "format": " ¾░Éź ",
    "tooltip": false,
    "on-click": "wlogout"
  },

  "clock": {
    // "format": "\uf017 {:%H:%M  \udb80\udced %e %b}",
    "format": "{:%H:%M %d.%m.%Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "today-format": "<b>{}</b>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 4,
      "format": {
        "today": "<span color='#82dccc'><b><u>{}</u></b></span>"
      }
    }
  },

  "cpu": {
    "interval": 1,
    "format": "\uf2db {max_frequency}GHz <span color=\"darkgray\">| {usage}%</span>",
    "max-length": 13,
    "min-length": 13
  },

  "hyprland/workspaces": {
    "all-outputs": true,
    "format": "{name}",
    "format-icons": {
      "1": "õĖĆ",
      "2": "õ║ī",
      "3": "õĖē",
      "4": "Õøø",
      "5": "õ║ö",
      "6": "ÕģŁ",
      "7": "õĖā",
      "8": "Õģ½",
      "9": "õ╣Ø",
      "10": "ÕŹü"
    },
    "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
    "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
    "sort-by-number": true,
    "active-only": false
  },

  "hyprland/window": {
    "max-length": 100,
    "separate-outputs": false
  },

  "wireplumber": {
    "on-click": "pavucontrol",
    "on-click-right": "amixer sset Master toggle 1>/dev/null",
    //on-click: "${wpctl} set-mute @DEFAULT_AUDIO_SINK@ toggle";
    //on-scroll-down: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04+";
    //on-scroll-up: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04-";
    "format": "<span>{icon}</span>{volume}%",
    "format-muted": "Ņ╗©",
    "format-source": "’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź ",
      "hands-free": "’¢É ",
      "headset": "’¢É ",
      "phone": "’éĢ ",
      "portable": "’éĢ ",
      "car": "’å╣ ",
      "default": ["’Ć” ", "’Ć¦ ", "’Ć© "]
    }
  },

  "hyprland/language": {
    "format": "<span rise='-1000'>’ä£</span> {shortDescription}",
    "on-click": "hyprctl switchxkblayout all next -q",
    "keyboard-name": "kbdfans-og60-keyboard"
  },

  "custom/vpn": {
    "interval": 3,
    "format": "<span>{icon}</span> {text}",
    "format-icons": {
      "on": "\udb83\udc53",
      "off": "\udb83\udc5f"
    },
    "return-type": "json",
    "exec": "ip add show | grep -qF wg0 && echo '{\"text\": \"on\", \"alt\": \"on\"}' || echo '{\"text\": \"off\", \"alt\": \"off\"}'",
    "on-click": "~/.config/waybar/modules/toggle-vpn.sh"
  },

  "custom/theme": {
    "interval": 10,
    "format": "{icon}",
    "format-icons": {
      "dark": "’åå",
      "light": "’öó"
    },
    "return-type": "json",
    "exec": "[[ $(gsettings get org.gnome.desktop.interface gtk-theme) =~ 'Dark' ]] && echo '{\"text\": \"dark\", \"alt\": \"dark\"}' || echo '{\"text\": \"light\", \"alt\": \"light\"}'",
    "on-click": "~/.config/waybar/modules/toggle-theme.sh"
  },


  "custom/camera": {
    "interval": 5,
    "format": "\uf030",
    "exec": "systemctl --user status camera.service &>/dev/null && echo 'on' || echo ''",
    "hide-empty-text": true,
    "on-click": "systemctl --user stop camera.service"
  },

  "custom/task": {
    "interval": 1,
    "format": "<span weight='bold'>Current task:</span> {text}",
    "exec": "cat /home/karevulli/projects/super-productivity-waybar/current-task.txt"
  },

  "tray": {
    "icon-size": 14,
    "spacing": 10
  },

  "network": {
    "format": "\udb80\uddda {bandwidthDownBits} \udb81\udd52 {bandwidthUpBits}",
    "interval": 2,
    "format-disconnected": "",
    "tooltip-format": "{ifname} \udb80\uddda {bandwidthDownBits} \udb81\udd52 {bandwidthUpBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50
  },

  "bluetooth": {
    "format-on": "’Ŗö",
    "format-off": "¾░é▓",
    "format-disabled": "", // an empty format will hide the module
    "format-no-controller": "",
    "format-connected": "¾░é▒",
    "tooltip": true,
	  "tooltip-format": "Bluetooth Settings",
    "tooltip-format-connected": "{num_connections} devices connected",
    "on-click": "overskride"
  }
}
